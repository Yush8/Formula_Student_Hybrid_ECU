/* =====================================================================
 *  FDCAN2 (tractive system / inverter bus) - RECEIVED message list.
 *
 *  Same rules as can1_messages.def:
 *
 *        CAN_MSG( SLOT_NAME , 0xID )
 *
 *  one line each, no trailing comma, no backslashes.
 *
 *  No live messages yet. To add one, copy a line out of the example
 *  comment below, remove the comment, rename it and set the real id.
 * ===================================================================== */

CAN_MSG(CAN2_BMS_Limits, 0x6B1)
CAN_MSG(CAN2_ODrive_0_VI, 0x017)
CAN_MSG(CAN2_ODrive_1_VI, 0x037)
CAN_MSG(CAN2_ODrive_0_Heartbeat, 0x001)
CAN_MSG(CAN2_ODrive_1_Heartbeat, 0x021)

/* --- Examples: copy a line out of this comment, rename it, set the id ---

# STM32CubeIDE build output (a bare name matches at any depth, e.g. CM4/Debug/)
Debug/
Release/

# Build artifacts
*.o
*.d
*.elf
*.bin
*.hex
*.map
*.list
*.su
*.cyclo

# IDE / OS junk
.DS_Store
Thumbs.db
*.bak
*.tmp

# Simulink / Embedded Coder build cache (generated, machine-local).
# NOTE: the generated *_ert_rtw source folder IS tracked on purpose - it is what
# the STM32 firmware compiles. Only the throwaway cache is ignored here.
slprj/
*.slxc
*.autosave

# Captured SD-card data logs
LOG*.csv

# Python (ConfigGUI)
__pycache__/
*.pyc
.venv/
venv/

# ConfigGUI remembered port / baud (per-machine, not source)
ConfigGUI.settings.json
